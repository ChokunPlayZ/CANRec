#!/bin/sh
# /etc/dropbear is bind-mounted over a tmpfs dir at boot (see inittab),
# so -R can create host keys there despite the read-only root.
case "$1" in
    start)
        printf "Starting SSH: "
        dropbear -R
        echo "OK"
        ;;
    stop)
        printf "Stopping SSH: "
        kill "$(cat /var/run/dropbear.pid 2>/dev/null)" 2>/dev/null || true
        echo "OK"
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
