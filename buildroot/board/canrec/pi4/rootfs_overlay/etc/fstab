# /etc/fstab
# Root is mounted ro by the kernel cmdline — listed here for completeness only.
proc      /proc   proc    defaults                          0 0
sysfs     /sys    sysfs   defaults                          0 0
devtmpfs  /dev    devtmpfs defaults,mode=755                0 0
tmpfs     /tmp    tmpfs   defaults,nosuid,nodev,size=64m    0 0
tmpfs     /run    tmpfs   defaults,nosuid,nodev,mode=755,size=32m  0 0
